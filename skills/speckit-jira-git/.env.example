# Atlassian Cloud Jira credentials.
# Copy this file to your PROJECT ROOT as `.env`, fill in your own values,
# and make sure `.env` is listed in your project's .gitignore. The scripts
# in this skill auto-discover the .env from any subdirectory of the project.
#
# NEVER commit a real .env to source control.

JIRA_URL=https://your-tenant.atlassian.net
JIRA_EMAIL=your-atlassian-email@example.com
JIRA_TOKEN=create-one-at-id.atlassian.com/manage-profile/security/api-tokens
JIRA_PROJECT=YOUR_PROJECT_KEY

# Optional. If unset, GitHub scripts use `gh auth token`.
GITHUB_TOKEN=
