{
  "name": "@kartikdp/speckit-jira-git",
  "version": "0.1.0",
  "description": "Portable Spec Kit, Jira, and GitHub workflow skill for coding agents.",
  "type": "module",
  "bin": {
    "speckit-jira-git": "skills/speckit-jira-git/bin/speckit-jira-git.js"
  },
  "files": [
    "README.md",
    "LICENSE",
    "NOTICE",
    "skills/speckit-jira-git"
  ],
  "scripts": {
    "check": "node skills/speckit-jira-git/bin/speckit-jira-git.js --help && python3 tests/check_python_syntax.py",
    "test": "PYTHONDONTWRITEBYTECODE=1 python3 -m unittest discover -s tests -p 'test_*.py'",
    "validate-skill": "python3 tests/validate_skill.py",
    "prepack": "npm run check && npm test && npm run validate-skill"
  },
  "keywords": [
    "agent-skills",
    "jira",
    "github",
    "speckit",
    "developer-tools",
    "workflow-automation"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kartikdp/speckit-jira-git.git"
  },
  "bugs": {
    "url": "https://github.com/kartikdp/speckit-jira-git/issues"
  },
  "homepage": "https://github.com/kartikdp/speckit-jira-git#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
